<?xml version="1.0"?>
<robot name="diffbot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:property name="base_length" value="0.46"/>
  <xacro:property name="base_width" value="0.32"/>
  <xacro:property name="base_height" value="0.18"/>
  <xacro:property name="wheel_radius" value="0.085"/>
  <xacro:property name="wheel_width" value="0.045"/>
  <xacro:property name="wheel_y" value="0.205"/>
  <xacro:property name="wheel_x" value="0.02"/>
  <xacro:property name="wheel_z" value="0.085"/>
  <xacro:property name="caster_radius" value="0.035"/>
  <xacro:property name="caster_z" value="${-base_height / 2.0}"/>
  <material name="body_blue"><color rgba="0.05 0.22 0.55 1"/></material>
  <material name="top_silver"><color rgba="0.75 0.8 0.86 1"/></material>
  <material name="wheel_black"><color rgba="0.02 0.02 0.025 1"/></material>
  <material name="rim_gray"><color rgba="0.45 0.48 0.52 1"/></material>
  <material name="accent_orange"><color rgba="1.0 0.45 0.08 1"/></material>
  <material name="sensor_glass"><color rgba="0.02 0.08 0.12 0.75"/></material>
  <material name="lidar_dark"><color rgba="0.01 0.015 0.02 1"/></material>
  <material name="lidar_blue"><color rgba="0.1 0.75 0.95 0.85"/></material>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_height / 2.0 + 0.035}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.045" ixy="0" ixz="0" iyy="0.075" iyz="0" izz="0.095"/>
    </inertial>
    <collision name="base_collision">
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
    </collision>
    <visual name="main_body">
      <geometry><box size="${base_length} ${base_width} ${base_height}"/></geometry>
      <material name="body_blue"/>
    </visual>
    <visual name="top_plate">
      <origin xyz="0.02 0 ${base_height / 2.0 + 0.018}"/>
      <geometry><box size="0.34 0.24 0.026"/></geometry>
      <material name="top_silver"/>
    </visual>
    <visual name="upper_shell">
      <origin xyz="-0.03 0 ${base_height / 2.0 + 0.055}"/>
      <geometry><box size="0.28 0.20 0.07"/></geometry>
      <material name="body_blue"/>
    </visual>
    <visual name="orange_side_left">
      <origin xyz="-0.02 ${base_width / 2.0 + 0.006} 0.015"/>
      <geometry><box size="0.30 0.012 0.035"/></geometry>
      <material name="accent_orange"/>
    </visual>
    <visual name="orange_side_right">
      <origin xyz="-0.02 ${-base_width / 2.0 - 0.006} 0.015"/>
      <geometry><box size="0.30 0.012 0.035"/></geometry>
      <material name="accent_orange"/>
    </visual>
    <visual name="front_bumper">
      <origin xyz="${base_length / 2.0 + 0.018} 0 -0.015"/>
      <geometry><box size="0.035 0.25 0.045"/></geometry>
      <material name="accent_orange"/>
    </visual>
    <visual name="left_light">
      <origin xyz="${base_length / 2.0 + 0.021} 0.075 0.025"/>
      <geometry><box size="0.012 0.055 0.025"/></geometry>
      <material name="accent_orange"/>
    </visual>
    <visual name="right_light">
      <origin xyz="${base_length / 2.0 + 0.021} -0.075 0.025"/>
      <geometry><box size="0.012 0.055 0.025"/></geometry>
      <material name="accent_orange"/>
    </visual>
  </link>

  <link name="left_wheel_link">
    <inertial>
      <mass value="0.45"/>
      <inertia ixx="0.0012" ixy="0" ixz="0" iyy="0.0012" iyz="0" izz="0.0020"/>
    </inertial>
    <collision>
      <origin rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <visual name="tire">
      <origin rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="wheel_black"/>
    </visual>
    <visual name="rim">
      <origin rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder radius="0.045" length="${wheel_width + 0.006}"/></geometry>
      <material name="rim_gray"/>
    </visual>
  </link>

  <link name="right_wheel_link">
    <inertial>
      <mass value="0.45"/>
      <inertia ixx="0.0012" ixy="0" ixz="0" iyy="0.0012" iyz="0" izz="0.0020"/>
    </inertial>
    <collision>
      <origin rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </collision>
    <visual name="tire">
      <origin rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      <material name="wheel_black"/>
    </visual>
    <visual name="rim">
      <origin rpy="${pi / 2.0} 0 0"/>
      <geometry><cylinder radius="0.045" length="${wheel_width + 0.006}"/></geometry>
      <material name="rim_gray"/>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="${wheel_x} ${wheel_y} ${-base_height / 2.0 + wheel_z - 0.035}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="${wheel_x} ${-wheel_y} ${-base_height / 2.0 + wheel_z - 0.035}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_caster_link">
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.00015"/>
    </inertial>
    <collision>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <surface>
        <friction>
          <ode><mu>0.01</mu><mu2>0.01</mu2></ode>
        </friction>
      </surface>
    </collision>
    <visual>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="rim_gray"/>
    </visual>
  </link>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster_link"/>
    <origin xyz="0.18 0 ${caster_z}" rpy="0 0 0"/>
  </joint>

  <link name="rear_caster_link">
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.00015"/>
    </inertial>
    <collision>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <surface>
        <friction>
          <ode><mu>0.01</mu><mu2>0.01</mu2></ode>
        </friction>
      </surface>
    </collision>
    <visual>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="rim_gray"/>
    </visual>
  </link>

  <joint name="rear_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_caster_link"/>
    <origin xyz="-0.20 0 ${caster_z}" rpy="0 0 0"/>
  </joint>

  <link name="sensor_mast_link">
    <collision>
      <origin xyz="0 0 0.045"/>
      <geometry><cylinder radius="0.015" length="0.09"/></geometry>
    </collision>
    <visual name="mast">
      <origin xyz="0 0 0.045"/>
      <geometry><cylinder radius="0.015" length="0.09"/></geometry>
      <material name="rim_gray"/>
    </visual>
    <visual name="sensor_head">
      <origin xyz="0.025 0 0.105"/>
      <geometry><box size="0.075 0.08 0.045"/></geometry>
      <material name="sensor_glass"/>
    </visual>
  </link>

  <joint name="sensor_mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_mast_link"/>
    <origin xyz="0.08 0 ${base_height / 2.0 + 0.015}" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <inertial>
      <mass value="0.18"/>
      <inertia ixx="0.00025" ixy="0" ixz="0" iyy="0.00025" iyz="0" izz="0.00035"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0.025"/>
      <geometry><cylinder radius="0.055" length="0.05"/></geometry>
    </collision>
    <visual name="lidar_base">
      <origin xyz="0 0 0.018"/>
      <geometry><cylinder radius="0.06" length="0.036"/></geometry>
      <material name="lidar_dark"/>
    </visual>
    <visual name="lidar_scan_band">
      <origin xyz="0 0 0.045"/>
      <geometry><cylinder radius="0.052" length="0.022"/></geometry>
      <material name="lidar_blue"/>
    </visual>
    <visual name="lidar_cap">
      <origin xyz="0 0 0.064"/>
      <geometry><cylinder radius="0.045" length="0.016"/></geometry>
      <material name="lidar_dark"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="-0.08 0 ${base_height / 2.0 + 0.095}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${2.0 * wheel_y}</wheel_separation>
      <wheel_diameter>${2.0 * wheel_radius}</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
    </plugin>
  </gazebo>
</robot>
